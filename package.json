{
  "name": "premium-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build:frontend": "node build.cjs",
    "build:server": "node -e \"require('child_process').execSync('npx tsc -p tsconfig.server.json',{stdio:'inherit',cwd:process.cwd()})\"",
    "build": "npm run build:frontend && npm run build:server",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chart.js": "^4.4.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
